# --- Swift / Xcode ---
xcuserdata/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
.build/
.swiftpm/
Package.resolved
DerivedData/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.so

# --- uv ---
# uv.lock IS checked in; only ignore caches
.uv-cache/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# --- Editors ---
.idea/
.vscode/
*.swp
*.swo

# --- Project artifacts ---
# secrets.env plus any atomic-write temp (secrets.env.writing) or backup (SEC11).
secrets.env*
*.local.toml
*.wav
*.mp3
*.m4a
*.summary.md
*.meta.json
# CI2: the cross-language contract golden sidecars are committed on purpose
# (named *.meta.json so the Python reader resolves them as their own sidecar).
!daemon/Tests/MeetingPipeTests/Fixtures/meta-contract/*.meta.json
*.json.bak
recordings/
.notion-cassettes/
# dogfood / engine-comparison per-meeting outputs carry real summary content
# (SEC11). Only the aggregate reports under docs/ are committed.
runs/

# --- Local tooling (not product) ---
# The impeccable design skill is installed locally and duplicated across
# harness dirs (.claude + .github); it is personal tooling, not product code.
# The project-specific design knowledge that IS tracked lives in PRODUCT.md
# and design/.
.claude/skills/
.github/skills/

# design-sync (claude.ai/design converter): regenerated locally, never committed.
# Durable inputs (config, NOTES, docs, fonts, previews, conventions) ARE committed.
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
design/.ds-entry.jsx

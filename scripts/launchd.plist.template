<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.meetingpipe.daemon</string>

  <key>ProgramArguments</key>
  <array>
    <string>{{INSTALL_PREFIX}}/MeetingPipe.app/Contents/MacOS/MeetingPipe</string>
  </array>

  <!-- Auto-start at login. Relaunch only on a non-zero exit: a clean quit
       (exit 0) means "quit fully" (TECH-UX7), while a crash or the
       relaunch-on-quit path (non-zero exit) brings the menu-bar app back. -->
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <!-- Don't fork-bomb if we're crashing on launch. -->
  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>{{HOME}}/Library/Logs/MeetingPipe/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>{{HOME}}/Library/Logs/MeetingPipe/launchd.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>

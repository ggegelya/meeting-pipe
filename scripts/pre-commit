#!/usr/bin/env bash
# Pre-commit hook that mirrors the CI em-dash rule from CONVENTIONS.md.
# Install with:
#   ln -sf ../../scripts/pre-commit .git/hooks/pre-commit
#
# Fails the commit when staged content introduces an em-dash (U+2014) on
# an added line. Historical em-dashes in untouched lines are out of scope
# (matches CONVENTIONS.md: "match the existing style of files you don't
# touch"). The rule lives in CONVENTIONS.md - link kept for the error
# message so the contributor can find the policy.
#
# Uses fgrep with the literal em-dash byte sequence so this script runs
# on BSD grep (macOS) without needing GNU PCRE.
set -e

EMDASH=$'\xe2\x80\x94'

# The exclusion list mirrors ci.yml's diff step exactly ("change one, change
# the other"): since 2026-07-13 neither ci.yml nor this script contains the
# raw character (both use the byte escape), so only the lockfiles stay excluded.
added=$(git diff --cached --unified=0 \
  ':!**/Package.resolved' \
  ':!**/uv.lock' \
  | grep '^+' | grep -v '^+++' || true)

if printf '%s' "$added" | grep -qF "$EMDASH"; then
  echo "pre-commit: em-dash detected in staged diff."
  echo "See CONVENTIONS.md ('No em-dashes'). Use a hyphen, comma, or rewrite."
  printf '%s\n' "$added" | grep -nF "$EMDASH" || true
  exit 1
fi

# TECH-UI-2: the daemon's UI sources + bundled resources stay entirely
# em-dash-free (whole staged tree, not just this diff), matching the CI guard
# so a backslide on an untouched line is caught locally too.
ui_emdash=$(git grep --cached -lF "$EMDASH" -- daemon/Sources daemon/Resources || true)
if [ -n "$ui_emdash" ]; then
  echo "pre-commit: em-dash in daemon/Sources or daemon/Resources (use a hyphen or rewrite):"
  git grep --cached -nF "$EMDASH" -- daemon/Sources daemon/Resources || true
  exit 1
fi

exit 0

{
  "projectId": "019de007-f4fd-7831-859a-f4c16bd4e53e",
  "shape": "package",
  "pkg": "meeting-pipe-design",
  "globalName": "MeetingPipe",
  "buildCmd": "node .design-sync/make-entry.mjs",
  "entry": "design/.ds-entry.jsx",
  "srcDir": "ui_kits/macos_app",
  "cssEntry": "colors_and_type.css",
  "extraFonts": ["../.design-sync/fonts/fonts.css"],
  "docsDir": "../.design-sync/docs",
  "guidelinesGlob": ["README.md"],
  "readmeHeader": ".design-sync/conventions.md",
  "overrides": {
    "Notification": { "cardMode": "column" },
    "MeetingPrompt": { "cardMode": "column" },
    "PreferencesWindow": { "cardMode": "column" },
    "SummaryLibrary": { "cardMode": "column" },
    "PWSlider": { "cardMode": "column" },
    "PWGroup": { "cardMode": "column" },
    "PWRow": { "cardMode": "column" },
    "PermRow": { "cardMode": "column" },
    "SLActionItem": { "cardMode": "column" },
    "SLBullets": { "cardMode": "column" },
    "SLEmpty": { "cardMode": "column" },
    "SLSection": { "cardMode": "column" }
  },
  "componentSrcMap": {
    "Icon": "ui_kits/macos_app/Icons.jsx",
    "MeetingPrompt": "ui_kits/macos_app/MeetingPrompt.jsx",
    "MenuBarDropdown": "ui_kits/macos_app/MenuBarDropdown.jsx",
    "Notification": "ui_kits/macos_app/Notification.jsx",
    "OnboardingPermissions": "ui_kits/macos_app/OnboardingPermissions.jsx",
    "PreferencesWindow": "ui_kits/macos_app/PreferencesWindow.jsx",
    "SummaryLibrary": "ui_kits/macos_app/SummaryLibrary.jsx",
    "PromptButton": "ui_kits/macos_app/MeetingPrompt.jsx",
    "MenuItem": "ui_kits/macos_app/MenuBarDropdown.jsx",
    "MenuSep": "ui_kits/macos_app/MenuBarDropdown.jsx",
    "PermRow": "ui_kits/macos_app/OnboardingPermissions.jsx",
    "PWGroup": "ui_kits/macos_app/PreferencesWindow.jsx",
    "PWRow": "ui_kits/macos_app/PreferencesWindow.jsx",
    "PWToggle": "ui_kits/macos_app/PreferencesWindow.jsx",
    "PWField": "ui_kits/macos_app/PreferencesWindow.jsx",
    "PWSegmented": "ui_kits/macos_app/PreferencesWindow.jsx",
    "PWSlider": "ui_kits/macos_app/PreferencesWindow.jsx",
    "PWStatusPill": "ui_kits/macos_app/PreferencesWindow.jsx",
    "PWTag": "ui_kits/macos_app/PreferencesWindow.jsx",
    "SLStatusPill": "ui_kits/macos_app/SummaryLibrary.jsx",
    "SLSegmented": "ui_kits/macos_app/SummaryLibrary.jsx",
    "SLEmpty": "ui_kits/macos_app/SummaryLibrary.jsx",
    "SLSection": "ui_kits/macos_app/SummaryLibrary.jsx",
    "SLBullets": "ui_kits/macos_app/SummaryLibrary.jsx",
    "SLActionItem": "ui_kits/macos_app/SummaryLibrary.jsx"
  },
  "dtsPropsFor": {
    "Icon": "name: 'mic' | 'waveform' | 'waveform-circle' | 'settings' | 'sliders' | 'cpu' | 'plug' | 'shield' | 'command' | 'folder' | 'file-text' | 'monitor' | 'book' | 'check-circle' | 'circle' | 'seal-check' | 'checklist' | 'help-bubble' | 'message' | 'users' | 'alert' | 'alert-triangle' | 'search' | 'play' | 'pause' | 'stop' | 'external' | 'chevron-right' | 'chevron-down' | 'lock' | 'user' | 'tray' | 'calendar' | 'tag' | 'plus' | 'pencil' | 'more' | 'more-circle' | 'gauge' | 'eye' | 'eye-off' | 'stethoscope' | 'refresh' | 'bell' | 'trash' | 'x' | 'logomark'; size?: number; title?: string;",
    "MeetingPrompt": "source?: { displayName: string }; workflow?: { name: string; color: string } | null; timeoutSec?: number; onRecord?: () => void; onSkip?: () => void; onAlways?: () => void; onBYO?: () => void;",
    "MenuBarDropdown": "state?: 'idle' | 'recording' | 'prompting' | 'stopping' | 'handoff'; source?: { displayName: string }; file?: string;",
    "Notification": "kind?: 'started' | 'processing' | 'done' | 'error'; title?: string; body?: string; action?: string;",
    "PromptButton": "children?: React.ReactNode; primary?: boolean; chevron?: boolean; onClick?: () => void; title?: string;",
    "MenuItem": "children?: React.ReactNode; shortcut?: string; header?: boolean; disabled?: boolean; mono?: boolean;",
    "PermRow": "icon: string; name: string; why: string; state: 'granted' | 'needed'; cta?: string;",
    "PWGroup": "label?: string; footer?: React.ReactNode; children?: React.ReactNode;",
    "PWRow": "label: React.ReactNode; sublabel?: React.ReactNode; children?: React.ReactNode; alignTop?: boolean; first?: boolean;",
    "PWToggle": "on?: boolean;",
    "PWField": "value?: string; placeholder?: string; mono?: boolean; width?: number | string;",
    "PWSegmented": "options: string[]; selected?: number;",
    "PWSlider": "value: number; max: number; format: string; valueWidth?: number;",
    "PWStatusPill": "tone: 'granted' | 'needed' | 'denied' | 'neutral'; icon: string; text: string;",
    "PWTag": "children?: React.ReactNode;",
    "SLStatusPill": "status: 'ready' | 'recording' | 'processing' | 'paste' | 'failed' | 'partial' | 'unpublished' | 'local';",
    "SLSegmented": "options: string[]; selected?: number;",
    "SLEmpty": "icon: string; title: string; body?: string; action?: string;",
    "SLSection": "icon: string; title: string; children?: React.ReactNode; right?: React.ReactNode;",
    "SLBullets": "items: React.ReactNode[]; numbered?: boolean;",
    "SLActionItem": "task: string; owner?: string; due?: string; confidence?: 'high';"
  }
}

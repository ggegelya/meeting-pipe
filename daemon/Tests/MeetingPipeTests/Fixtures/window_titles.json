      "state": "schedule_dialog",
      "expected": "reject",
      "seeded": true,
      "titles": ["Zoom", "Schedule Meeting"]
    },
    {
      "bundle_id": "us.zoom.xos",
      "state": "join_dialog",
      "expected": "reject",
      "seeded": true,
      "titles": ["Zoom", "Join Meeting"]
    },
